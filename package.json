{
	"name": "svelte-cloudflare-d1",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run build && wrangler pages dev",
		"deploy": "npm run build && wrangler pages deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 execute argasso-production --local --file=migrations/0000_first_serpent_society.sql",
		"db:migrate:prod": "wrangler d1 execute argasso-production --remote --file=migrations/0000_first_serpent_society.sql",
		"db:migrate:preview": "wrangler d1 execute argasso-preview --remote --file=migrations/0000_first_serpent_society.sql",
		"db:studio:local": "drizzle-kit studio",
		"db:studio:prod": "drizzle-kit studio",
		"import": "tsx scripts/import/index.ts",
		"import:products": "tsx scripts/import/products.ts",
		"import:pages": "tsx scripts/import/metaobjects.ts",
		"import:authors": "tsx scripts/import/authors.ts",
		"link-categories": "tsx scripts/import/link-categories.ts",
		"verify-data": "tsx scripts/verify-data.ts",
		"register-webhooks": "tsx scripts/register-webhooks.ts",
		"cf-typegen": "wrangler types",
		"tada-generate": "gql.tada generate-schema ./schema.graphql",
		"tada-doctor": "gql.tada doctor",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@libsql/client": "^0.14.0",
		"@lucide/svelte": "^1.7.0",
		"@tiptap/core": "^3.14.0",
		"@tiptap/extension-blockquote": "^3.14.0",
		"@tiptap/extension-bold": "^3.14.0",
		"@tiptap/extension-bullet-list": "^3.14.0",
		"@tiptap/extension-code": "^3.14.0",
		"@tiptap/extension-code-block": "^3.14.0",
		"@tiptap/extension-document": "^3.14.0",
		"@tiptap/extension-hard-break": "^3.14.0",
		"@tiptap/extension-heading": "^3.14.0",
		"@tiptap/extension-history": "^3.14.0",
		"@tiptap/extension-horizontal-rule": "^3.14.0",
		"@tiptap/extension-image": "^3.14.0",
		"@tiptap/extension-italic": "^3.14.0",
		"@tiptap/extension-link": "^3.14.0",
		"@tiptap/extension-list-item": "^3.14.0",
		"@tiptap/extension-ordered-list": "^3.14.0",
		"@tiptap/extension-paragraph": "^3.14.0",
		"@tiptap/extension-strike": "^3.14.0",
		"@tiptap/extension-table": "^3.14.0",
		"@tiptap/extension-table-cell": "^3.14.0",
		"@tiptap/extension-table-header": "^3.14.0",
		"@tiptap/extension-table-row": "^3.14.0",
		"@tiptap/extension-text": "^3.14.0",
		"@tiptap/starter-kit": "^3.14.0",
		"@urql/core": "^5.1.1",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"drizzle-valibot": "^0.4.2",
		"formsnap": "^2.0.1",
		"gql.tada": "^1.8.10",
		"jose": "^5.9.6",
		"mode-watcher": "^1.1.0",
		"svelte-tiptap": "^3.0.1",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@0no-co/graphqlsp": "^1.12.16",
		"@cloudflare/workers-types": "^4.20250405.0",
		"@sveltejs/adapter-cloudflare": "^7.0.1",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.9",
		"@types/node": "^22.15.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.21.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.17.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.0.9",
		"tsx": "^4.19.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.21.0",
		"vite": "^7.3.1",
		"wrangler": "^4.12.0"
	}
}
