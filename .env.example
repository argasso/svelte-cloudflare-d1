# Local Development
DATABASE_URL=file:local.db
LOCAL_DB_PATH=file:local.db

# Shopify (use wrangler secrets for production)
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Cloudflare (for remote D1 operations)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=24adda0d-bab7-4874-9e41-7827df8ef443
CLOUDFLARE_D1_TOKEN=

# Cloudflare Access — protects /admin in production (set as Pages secrets/vars).
# Without these, /admin returns 403 when deployed (fail-closed).
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=

# Webhook callback base URL for `npm run register-webhooks` (your deployed URL)
SHOPIFY_WEBHOOK_CALLBACK_URL=
